# ========================================
# AutoWork AI — 환경변수 템플릿
# 실제 값을 .env.local 파일에 복사하여 사용
# ========================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Anthropic (Claude Sonnet 4.6) ----
ANTHROPIC_API_KEY=your_anthropic_api_key

# ---- OpenAI (Whisper + Embeddings) ----
OPENAI_API_KEY=your_openai_api_key

# ---- 토스페이먼츠 ----
TOSS_CLIENT_KEY=test_ck_YOUR_CLIENT_KEY
TOSS_SECRET_KEY=test_sk_YOUR_SECRET_KEY

# ---- Redis (Upstash) ----
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ---- Slack ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8000
NODE_ENV=development

# ---- FastAPI ----
SECRET_KEY=your_jwt_secret_key_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
