# ========================================
# n8n 인프라 환경변수 템플릿
# 실제 값을 .env 파일에 복사하여 사용
# ========================================

# ---- n8n 기본 설정 ----
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/

# ---- n8n 인증 ----
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here

# ---- PostgreSQL (n8n 전용) ----
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_postgres_password_here

# ========================================
# 콘텐츠 파이프라인 API 키
# (n8n Credentials에 직접 입력해도 됨)
# ========================================

# ---- Anthropic (Claude Sonnet 4.6) ----
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# ---- YouTube Data API v3 ----
YOUTUBE_API_KEY=AIza_your_youtube_api_key_here
YOUTUBE_CLIENT_ID=your_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here
YOUTUBE_CHANNEL_ID=UCyour_channel_id_here

# ---- 티스토리 API ----
TISTORY_APP_ID=your_tistory_app_id
TISTORY_SECRET_KEY=your_tistory_secret_key
TISTORY_ACCESS_TOKEN=your_tistory_access_token
TISTORY_BLOG_NAME=your_blog_name

# ---- Instagram Graph API ----
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ---- 쿠팡 파트너스 API ----
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key

# ---- Google Trends & 네이버 DataLab ----
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ---- Supabase (파이프라인 데이터 저장) ----
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Slack (알림) ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
