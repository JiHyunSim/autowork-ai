# Core
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# WordPress REST API
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USER=your-wordpress-username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Coupang
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Pipeline
PIPELINE_API_TOKEN=
SLACK_WEBHOOK_URL=

# Google Cloud TTS (CMP-74) — 아래 둘 중 하나만 설정
# 방법 1: 서비스 계정 JSON 키 파일 경로 (권장)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# 방법 2: API 키 (제한된 기능)
# GOOGLE_API_KEY=

# TTS 음성 설정 (기본: ko-KR-Neural2-C)
# 옵션: ko-KR-Neural2-A, ko-KR-Neural2-B, ko-KR-Neural2-C, ko-KR-Neural2-D
GOOGLE_TTS_VOICE=ko-KR-Neural2-C

# 영상 생성 설정
VIDEO_OUTPUT_DIR=/tmp/youtube_videos
VIDEO_RENDER_ENABLED=true
